# Copy this file to `.env.local` (which is git-ignored) and fill in your keys.
#
# Only variables prefixed with VITE_ are exposed to the browser bundle.
# These are public/client-side — never put server secrets here.

# -----------------------------------------------------------------------------
# TinyMCE Cloud API key (optional)
# -----------------------------------------------------------------------------
# Without this, the editor still works under TinyMCE's open-source / no-api-key
# mode and shows a small "Build with TinyMCE" footer notice. Adding a key
# removes the notice and unlocks premium plugins on Tiny Cloud's free tier.
#
# Get a free key at https://www.tiny.cloud/auth/signup/ then paste it here:
VITE_TINYMCE_API_KEY=

# -----------------------------------------------------------------------------
# Default resume source (optional)
# -----------------------------------------------------------------------------
# URL to fetch the default resume JSON from at runtime — used as the seed when
# there's no saved resume and on Reset. Leave blank to use the resume bundled at
# src/data/default-resume.json. Example: https://example.com/resume.json
VITE_RESUME_DATA_URL=

# -----------------------------------------------------------------------------
# Editor auth (SERVER-SIDE ONLY — never exposed to the browser)
# -----------------------------------------------------------------------------
# EDITOR_PASSWORD gates the /editor route. Set it in your host's env vars
# (Netlify: Site settings → Environment variables) or in .env.local for dev.
EDITOR_PASSWORD=change-me

# AUTH_SECRET signs the session cookie. Generate a random value:
#   openssl rand -hex 32
AUTH_SECRET=
