{
  "name": "qwik-resume-editor",
  "description": "A Qwik-based resume editor with PDF/JSON export, drag-and-drop section reordering, and live preview.",
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "private": true,
  "trustedDependencies": {
    "sharp": "0.32.6"
  },
  "type": "module",
  "scripts": {
    "build": "vite build && vite build --config adapters/netlify-edge/vite.config.ts",
    "build.client": "vite build",
    "build.netlify": "vite build --config adapters/netlify-edge/vite.config.ts",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "build.server": "qwik check-client src dist && vite build -c adapters/netlify-edge/vite.config.ts",
    "build.types": "tsc --incremental --noEmit",
    "deploy": "netlify deploy --build",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "fmt": "prettier --write .",
    "fmt.check": "prettier --check .",
    "lint": "eslint \"src/**/*.ts*\"",
    "preview": "qwik build preview && vite preview --open",
    "start": "vite --open --mode ssr",
    "qwik": "qwik"
  },
  "devDependencies": {
    "@builder.io/qwik": "^1.5.7",
    "@builder.io/qwik-city": "^1.5.7",
    "@netlify/edge-functions": "^2.0.0",
    "@types/eslint": "^8.56.10",
    "@types/node": "^20.14.2",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-plugin-qwik": "^1.5.7",
    "netlify-cli": "^15.0.0",
    "postcss": "^8.4.38",
    "prettier": "^3.3.1",
    "tailwindcss": "^3.4.4",
    "typescript": "5.4.5",
    "undici": "^6.21.3",
    "vite": "^5.2.13",
    "vite-tsconfig-paths": "^4.3.2"
  },
  "dependencies": {
    "@auth/qwik": "^0.9.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.1"
  }
}
